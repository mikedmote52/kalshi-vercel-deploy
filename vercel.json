{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "",
  "outputDirectory": "public",
  "functions": {
    "api/*.js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/scan",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/scan",
      "schedule": "30 20 * * 1-5"
    }
  ]
}
